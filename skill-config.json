{
  "version": "1.0.0",
  "clarification": {
    "confidence_threshold": 0.90,
    "min_questions_per_round": 2,
    "max_questions_per_round": 5
  },
  "rag": {
    "enabled": true,
    "chunk_size": 1000,
    "chunk_overlap": 200,
    "max_results": 10,
    "similarity_threshold": 0.7
  },
  "vision": {
    "provider": "anthropic",
    "fallback_providers": ["openai", "gemini", "apple"],
    "max_retries": 3
  },
  "verification": {
    "enabled": true,
    "num_judges": 3,
    "consensus_threshold": 0.66
  },
  "thinking": {
    "default_strategy": "verified_reasoning",
    "extended_thinking_enabled": true,
    "available_strategies": [
      "chain_of_thought",
      "tree_of_thoughts",
      "graph_of_thoughts",
      "react",
      "reflexion",
      "plan_and_solve",
      "verified_reasoning",
      "recursive_refinement",
      "zero_shot",
      "few_shot",
      "self_consistency",
      "generate_knowledge",
      "prompt_chaining",
      "multimodal_cot",
      "meta_prompting"
    ]
  },
  "output": {
    "format": "markdown",
    "include_metadata": true,
    "include_confidence_scores": true,
    "include_verification_results": true
  },
  "integrations": {
    "github": {
      "enabled": true,
      "auth_method": "gh_cli",
      "scopes": ["repo", "read:org"]
    },
    "jira": {
      "enabled": false,
      "url": "",
      "client_id": "",
      "client_secret": "",
      "project_key": ""
    }
  }
}
